TRIGGER FOR EVERY UPDATION EMP2

CREATE OR REPLACE TRIGGER SAL_AUD 
AFTER UPDATE OF SALARY ON EMP2 
FOR EACH ROW
BEGIN 
  INSERT INTO EMP2_AUD(EMPNO,NAME,CATEGORY,SALARY,NEW_SALARY,MOD_DATE) VALUES(:OLD.EMPNO,:OLD.NAME,:OLD.CATEGORY,:OLD.SALARY,:NEW.SALARY,SYSDATE);
END;
/
Trigger created.

